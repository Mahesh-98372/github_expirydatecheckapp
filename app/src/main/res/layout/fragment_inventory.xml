<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Header Section -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/colorPrimary"
        android:paddingHorizontal="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="Inventory"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/white" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Search Bar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Search"
                android:background="@android:color/transparent"
                android:paddingHorizontal="16dp"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="8dp"
                android:textSize="14sp"
                android:inputType="text"
                android:importantForAccessibility="no" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Category Filter -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/tvFilterAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ALL"
                    android:background="@drawable/bg_chip_selected"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tvFilterDairy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DAIRY"
                    android:background="@drawable/bg_chip_unselected"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/text_grey"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tvFilterPharma"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PHARMA"
                    android:background="@drawable/bg_chip_unselected"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/text_grey"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tvFilterPantry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PANTRY"
                    android:background="@drawable/bg_chip_unselected"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/text_grey"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tvFilterMeat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MEAT"
                    android:background="@drawable/bg_chip_unselected"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/text_grey"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewInventory"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingBottom="80dp" />

    </LinearLayout>

    <!-- Floating Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/colorPrimary"
        app:tint="@color/white"
        android:contentDescription="Add New Item" />

</RelativeLayout>
